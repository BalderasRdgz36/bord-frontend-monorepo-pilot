GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo "${YELLOW}🔍 Formateando archivos staged...${NC}"

if ! npx lint-staged --config lint-staged.js; then
  echo "${RED}❌ lint-staged falló! Corrige los errores antes de hacer commit${NC}"
  exit 1
fi

echo "${YELLOW}🔍 Corriendo lint y typecheck sobre proyectos afectados...${NC}"

if npx nx affected -t lint,typecheck --uncommitted; then
  echo "${GREEN}✅ Validación exitosa! Continuando con el commit...${NC}"
else
  echo "${RED}❌ Validación falló! Corrige los errores antes de hacer commit${NC}"
  exit 1
fi
